def draw_shocked_1(display, buf):
    LINE_W = 3

    # ---- Left eye geometry ----
    L_BOX = (20, 15, 110, 130)                  # outer frame: x0,y0,x1,y1
    L_INNER = (38, 40, 95, 110)                 # inner frame
    L_BROW = (8, 5, 110, 8)                     # x0,y0,x1,y1 (y0/y1 = thickness)
    L_CURL_OX, L_CURL_OY = 52, 55
    L_CURL_PATH = [(0,0),(32,0),(32,40),(10,40),(10,12),(22,12),(22,26),(14,26)]

    # ---- Right eye geometry (mirrored around x=160) ----
    R_BOX = (320-110, 15, 320-20, 130)
    R_INNER = (320-95, 40, 320-38, 110)
    R_BROW = (320-110, 5, 320-8, 8)
    R_CURL_OX, R_CURL_OY = 320-84, 55
    R_CURL_PATH = [(32-x, y) for (x, y) in L_CURL_PATH]

    MOUTH_TOP_Y, MOUTH_BOTTOM_Y = 180, 235
    MOUTH_TOP_LEFT, MOUTH_TOP_RIGHT = 135, 185
    MOUTH_BOT_LEFT, MOUTH_BOT_RIGHT = 100, 220

    def hollow_rect_row_1(gy, box, row_offset):
        x0, y0, x1, y1 = box
        if y0 <= gy < y0 + LINE_W or y1 - LINE_W <= gy < y1:
            for x in range(x0, x1):
                if 0 <= x < 320:
                    buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00
        elif y0 <= gy < y1:
            for x in range(x0, x0+LINE_W):
                if 0 <= x < 320:
                    buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00
            for x in range(x1-LINE_W, x1):
                if 0 <= x < 320:
                    buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00

    def line_row_1(gy, box, row_offset):
        x0, y0, x1, y1 = box
        if y0 <= gy < y1:
            for x in range(x0, x1):
                if 0 <= x < 320:
                    buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00

    def spiral_row_1(gy, path, ox, oy, row_offset):
        for i in range(len(path)-1):
            x0, y0 = path[i]; x1, y1 = path[i+1]
            gx0, gy0 = ox+x0, oy+y0
            gx1, gy1 = ox+x1, oy+y1
            if gy0 == gy1:
                if gy0 <= gy < gy0+LINE_W:
                    lo, hi = (gx0, gx1) if gx0 < gx1 else (gx1, gx0)
                    for x in range(lo, hi+LINE_W):
                        if 0 <= x < 320:
                            buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00
            else:
                lo, hi = (gy0, gy1) if gy0 < gy1 else (gy1, gy0)
                if lo <= gy < hi+LINE_W:
                    for x in range(gx0, gx0+LINE_W):
                        if 0 <= x < 320:
                            buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00

    for chunk in range(15):
        start_y = chunk * 16
        buf[:] = b'\xFF' * len(buf)
        for local_y in range(16):
            global_y = start_y + local_y
            row_offset = local_y * 640

            if 0 <= global_y < 135:
                line_row_1(global_y, L_BROW, row_offset)
                line_row_1(global_y, R_BROW, row_offset)
                hollow_rect_row_1(global_y, L_BOX, row_offset)
                hollow_rect_row_1(global_y, R_BOX, row_offset)
                hollow_rect_row_1(global_y, L_INNER, row_offset)
                hollow_rect_row_1(global_y, R_INNER, row_offset)
                spiral_row_1(global_y, L_CURL_PATH, L_CURL_OX, L_CURL_OY, row_offset)
                spiral_row_1(global_y, R_CURL_PATH, R_CURL_OX, R_CURL_OY, row_offset)

            elif MOUTH_TOP_Y <= global_y < MOUTH_BOTTOM_Y:
                t = (global_y - MOUTH_TOP_Y) / (MOUTH_BOTTOM_Y - MOUTH_TOP_Y)
                left_x = int(MOUTH_TOP_LEFT + t * (MOUTH_BOT_LEFT - MOUTH_TOP_LEFT))
                right_x = int(MOUTH_TOP_RIGHT + t * (MOUTH_BOT_RIGHT - MOUTH_TOP_RIGHT))
                if global_y < MOUTH_TOP_Y + LINE_W or global_y >= MOUTH_BOTTOM_Y - LINE_W:
                    for x in range(left_x, right_x):
                        buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00
                else:
                    for x in range(left_x, left_x+LINE_W):
                        buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00
                    for x in range(right_x-LINE_W, right_x):
                        buf[row_offset+(x*2)] = 0x00; buf[row_offset+(x*2)+1] = 0x00

        display.block(0, start_y, 319, start_y + 15, buf)


