def draw_sad_eye_line(buf, row_offset, global_y, x0, x1, y0, y1, line_w):
    """Draws one straight eye line from (x0, y0) to (x1, y1), thickness line_w.
    y0 is the y-value at x0, y1 is the y-value at x1 - this is what creates
    the slant."""
    span = x1 - x0
    for x in range(x0, x1):
        t = (x - x0) / span
        y = int(y0 + t * (y1 - y0))
        if y <= global_y < y + line_w:
            buf[row_offset + (x * 2)] = 0x00
            buf[row_offset + (x * 2) + 1] = 0x00


